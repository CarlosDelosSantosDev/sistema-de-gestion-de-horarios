<Window x:Class="SistemaHorarios.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Horarios - UPGOP" 
        Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFFFF">

    <Grid>
        <!-- Layout de dos columnas -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo - Branding Institucional -->
        <Border Grid.Column="0" Background="#FF1E3A5F" Width="350">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <!-- Logo o Icono Académico -->
                <Viewbox Width="89" Height="88" Margin="0,0,0,20">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#FFFFFFFF" Data="M12,3L1,9L12,15L21,10.09V17H23V9M5,13.36V17H13V13.36L12,13L5,13.36Z"/>
                    </Canvas>
                </Viewbox>

                <!-- Nombre de la Institución -->

                <TextBlock Text="UNIVERSIDAD POLÍTECNICA" 
                         Foreground="White" 
                         FontSize="20" 
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,0"/>

                <TextBlock Text="DE GÓMEZ PALACIO" 
                         Foreground="White" 
                         FontSize="20" 
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,20"/>

                <!-- Línea decorativa -->
                <Border Height="2" Background="#FF4ECDC4" Margin="0,20,0,30" Width="100" HorizontalAlignment="Center"/>

                <!-- Texto descriptivo -->
                <TextBlock Text="Sistema de Gestión Académica" 
                         Foreground="#FFB0BEC5" 
                         FontSize="14" 
                         FontWeight="Normal"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Control de Horarios y Recursos" 
                         Foreground="#FFB0BEC5" 
                         FontSize="12" 
                         FontWeight="Light"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Panel derecho - Formulario de Login -->
        <Border Grid.Column="1" Background="#FFFFFFFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <!-- Título del Formulario -->
                <TextBlock Text="INICIAR SESIÓN" 
                         Foreground="#FF1E3A5F" 
                         FontSize="20" 
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,40"/>

                <!-- Campo Usuario -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Usuario" 
                             Foreground="#FF546E7A" 
                             FontSize="12" 
                             FontWeight="Medium"
                             Margin="0,0,0,5"/>

                    <TextBox x:Name="txtUsername" 
                           Height="42" 
                           Background="#FFF5F5F5" 
                           Foreground="#FF37474F"
                           BorderBrush="#FFE0E0E0" 
                           BorderThickness="1"
                           Padding="12" 
                           FontSize="14"
                           Text="admin"
                           CaretBrush="#FF1E3A5F">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF1E3A5F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <!-- Campo Contraseña -->
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="Contraseña" 
                             Foreground="#FF546E7A" 
                             FontSize="12" 
                             FontWeight="Medium"
                             Margin="0,0,0,5"/>

                    <PasswordBox x:Name="txtPassword" 
                               Height="42" 
                               Background="#FFF5F5F5" 
                               Foreground="#FF37474F"
                               BorderBrush="#FFE0E0E0" 
                               BorderThickness="1"
                               Padding="12" 
                               FontSize="14"
                               Password="123456">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF1E3A5F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                </StackPanel>

                <!-- Botón de Login -->
                <Button x:Name="btnLogin" 
                      Content="ACCEDER AL SISTEMA" 
                      Height="45" 
                      Background="#FF1E3A5F" 
                      Foreground="White"
                      FontWeight="SemiBold" 
                      FontSize="14"
                      BorderThickness="0" 
                      Cursor="Hand"
                      Click="BtnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF1E3A5F"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF2C4A75"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF153354"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Mensaje de estado -->
                <Border x:Name="messageBorder" 
                      Background="#FFF5F5F5" 
                      CornerRadius="4" 
                      Margin="0,20,0,0"
                      Visibility="Collapsed">
                    <TextBlock x:Name="txtMensaje" 
                             Foreground="#FF546E7A" 
                             FontSize="12" 
                             Margin="10"
                             TextWrapping="Wrap"
                             HorizontalAlignment="Center"/>
                </Border>

                <!-- Footer -->
                <TextBlock Text="© 2025 Dynamic Studios - Todos los derechos reservados" 
                         Foreground="#FF90A4AE" 
                         FontSize="10" 
                         Margin="0,40,0,0"
                         HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

<UserControl x:Class="SistemaHorarios.CarrerasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Gestión de Carreras" 
                     FontSize="20" FontWeight="Bold" 
                     Foreground="#FF1E3A5F"/>
            <TextBlock Text="Administra las carreras del sistema" 
                     Foreground="#FF546E7A" FontSize="14"/>
        </StackPanel>

        <!-- Botones de Acción -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
            <Button x:Name="btnAgregar" Content="➕ Agregar Carrera" 
                  Background="#FF1E3A5F" Foreground="White" 
                  Padding="15,8" Margin="0,0,10,0"
                  Click="BtnAgregar_Click"/>

            <Button x:Name="btnRefrescar" Content="🔄 Refrescar" 
                  Background="#FF546E7A" Foreground="White" 
                  Padding="15,8"
                  Click="BtnRefrescar_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                    Margin="0,0,0,20">
            <DataGrid x:Name="dgCarreras" 
                    AutoGenerateColumns="False" CanUserAddRows="False"
                    IsReadOnly="True" SelectionMode="Single" 
                    SelectionUnit="FullRow" MinHeight="300">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdCarrera}" Width="160"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="550"/>
                    <DataGridTextColumn Header="Clave" Binding="{Binding Clave}" Width="365"/>

                    <!-- Columna de Acciones -->
                    <DataGridTemplateColumn Header="Acciones" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Margin="2" Padding="8,5" 
                                          Click="BtnEditar_Click" 
                                          Tag="{Binding IdCarrera}"
                                          ToolTip="Editar carrera"
                                          Background="Transparent" BorderThickness="0"/>
                                    <Button Content="🗑️" Margin="2" Padding="8,5" 
                                          Click="BtnEliminar_Click" 
                                          Tag="{Binding IdCarrera}"
                                          ToolTip="Eliminar carrera"
                                          Background="Transparent" BorderThickness="0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <StatusBar Grid.Row="2" Background="#FFF5F5F5">
            <TextBlock x:Name="txtStatus" Text="Listo" Foreground="#FF546E7A"/>
        </StatusBar>
    </Grid>
</UserControl>
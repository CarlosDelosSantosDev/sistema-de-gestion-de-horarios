<UserControl x:Class="SistemaHorarios.HorarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel lateral -->
        <Border Grid.Column="0" Grid.Row="1" Background="#FFF5F5F5" Margin="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <!-- PERIODO -->
                    <TextBlock Text="PERIODO" FontWeight="Bold" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbPeriodo" Height="30" Margin="0,0,0,15" 
                              SelectionChanged="CmbPeriodo_SelectionChanged">
                        <ComboBoxItem Content="ENE-ABR 2026"/>
                        <ComboBoxItem Content="MAY-AGO 2026"/>
                        <ComboBoxItem Content="SEP-DIC 2026"/>
                        <ComboBoxItem Content="ENE-ABR 2027"/>
                        <ComboBoxItem Content="MAY-AGO 2027"/>
                        <ComboBoxItem Content="SEP-DIC 2027"/>
                        <ComboBoxItem Content="ENE-ABR 2028"/>
                        <ComboBoxItem Content="MAY-AGO 2028"/>
                        <ComboBoxItem Content="SEP-DIC 2028"/>
                    </ComboBox>

                    <!-- PROFESOR -->
                    <TextBlock Text="👥 PROFESOR" FontWeight="Bold" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbProfesores" Height="30" Margin="0,0,0,15"
                              DisplayMemberPath="NombreCompleto"
                              SelectedValuePath="NumeroTrabajador"
                              SelectionChanged="CmbProfesores_SelectionChanged"/>

                    <!-- MATERIAS -->
                    <TextBlock Text="📚 MATERIAS (Doble click para modo relleno)" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="Todas las materias disponibles" FontSize="10" Foreground="Gray" Margin="0,0,0,5"/>
                    <ListView x:Name="lstMaterias" Height="120" Margin="0,0,0,15"
          PreviewMouseLeftButtonDown="Elemento_PreviewMouseLeftButtonDown"
          SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <EventSetter Event="PreviewMouseDoubleClick" Handler="ListViewItem_PreviewMouseDoubleClick"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NombreCompleto}" Margin="2" FontSize="10"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- GRUPOS -->
                    <TextBlock Text="🔑 GRUPOS (Doble click para modo relleno)" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock x:Name="txtInfoGrupos" Text="Selecciona un periodo" FontSize="10" 
           Foreground="Gray" Margin="0,0,0,5"/>
                    <ListView x:Name="lstGrupos" Height="120" Margin="0,0,0,20"
          PreviewMouseLeftButtonDown="Elemento_PreviewMouseLeftButtonDown"
          SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <EventSetter Event="PreviewMouseDoubleClick" Handler="ListViewItem_PreviewMouseDoubleClick"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ClaveCompleta}" Margin="2" FontSize="10"/>
                                    <TextBlock Text="{Binding EsDelPeriodo}" Foreground="Green" FontSize="8" 
                           Margin="2,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- BOTÓN GUARDAR -->
                    <Button Content="💾 GUARDAR HORARIO ACTUAL"
                            Background="#FF1E3A5F"
                            Foreground="White"
                            FontSize="12"
                            FontWeight="Bold"
                            Height="35"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- PANEL HORARIO -->
        <Border Grid.Column="1" Grid.Row="1" Background="White" Margin="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,-59">
                <StackPanel Margin="10">
                    <TextBlock Text="HORARIO DEL PROFESOR:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtNombreHorario" Height="30" IsReadOnly="True" FontWeight="Bold" 
                             Background="#FFF5F5F5" Margin="0,0,0,15"/>

                    <!-- INFO HORAS -->
                    <TextBlock x:Name="txtInfoHoras" Text="Horas asignadas: 0/30" FontSize="11" 
                              Foreground="Gray" Margin="0,0,0,10"/>

                    <!-- GRILLA DE HORARIO -->
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5"
                            PreviewMouseRightButtonDown="GridHorario_PreviewMouseRightButtonDown">
                        <Grid x:Name="gridHorario" ShowGridLines="True" MinHeight="600" HorizontalAlignment="Stretch"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- BOTÓN CREAR OTRO HORARIO -->
        <Button Grid.Row="1"
                x:Name="btnCrearOtroHorario"
                Content="➕ CREAR OTRO HORARIO"
                Background="#FF4CAF50"
                Foreground="White"
                FontSize="12"
                FontWeight="Bold"
                Height="35"
                Margin="0,591,0,74"
                HorizontalAlignment="Center"
                Click="BtnCrearOtroHorario_Click"/>
    </Grid>
</UserControl>